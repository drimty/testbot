# Токен бота, полученный от @BotFather
BOT_TOKEN=123456789:AAExampleTokenReplaceMe

# ID администраторов через запятую (свой Telegram user id можно узнать у @userinfobot)
ADMIN_IDS=111111111,222222222

# Путь к файлу базы данных (можно оставить по умолчанию)
DB_PATH=tickets.db

# --- Необязательные настройки для группы с темами (форум) ---

# ID тем форума, в которых принимаются команды /bug и /feature.
# Оставьте пустым — команда работает в любой теме. Как узнать ID темы:
# перешлите любое сообщение из нужной темы боту-помощнику вроде @userinfobot,
# либо возьмите message_thread_id из логов бота при отправке в эту тему.
BUG_TOPIC_ID=
FEATURE_TOPIC_ID=

# Через сколько секунд удалять служебные сообщения в группе (/help, /bot,
# подсказки, редиректы). 0 — не удалять. Для удаления чужих сообщений боту
# нужно право администратора «Удалять сообщения». Заявки /bug, /feature и
# ответы о смене статуса НЕ удаляются.
EPHEMERAL_TTL=0
